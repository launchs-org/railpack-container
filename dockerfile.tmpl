# Railpack version {{.Version}}
FROM debian:stable-slim

# hadolint ignore=DL3008
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      curl \
      ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# mise のインストール
RUN curl -fsSL --proto '=https' --tlsv1.2 https://mise.run | sh

ENV PATH="/root/.local/bin:${PATH}"

# railpack を指定バージョンでインストールし、グローバルに有効化
RUN mise use --global "github:railwayapp/railpack@{{.Version}}"

# 動作確認
RUN railpack --version

ENTRYPOINT ["railpack"]
