# Railpack version 0.23.0
FROM debian:stable-slim

# パッケージのインストールと非ルートユーザーの作成
# hadolint ignore=DL3008
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      curl \
      ca-certificates \
 && useradd -m -s /bin/bash railuser \
 && rm -rf /var/lib/apt/lists/*

# 実行ユーザーの切り替え
USER railuser
WORKDIR /app

# パスの設定 (railpack のインストール先を優先)
ENV PATH="/home/railuser/.local/bin:${PATH}"

# Railpack のインストール
# 0.23.0 を環境変数として渡し、指定のディレクトリへインストール
RUN mkdir -p ~/.local/bin && \
    curl -sSL https://railpack.com/install.sh | RAILPACK_VERSION=0.23.0 sh -s -- --bin-dir ~/.local/bin

# 動作確認
RUN railpack --version

ENTRYPOINT ["railpack"]